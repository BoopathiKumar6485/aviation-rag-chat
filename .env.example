# OpenAI API (if using OpenAI)
OPENAI_API_KEY=your_openai_api_key_here

# Model configuration
LLM_MODEL=gpt-3.5-turbo  # or use "gpt-4" for better results

# Alternative: Use local model with Ollama
# OLLAMA_BASE_URL=http://localhost:11434
# LOCAL_MODEL=llama2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Vector Store
VECTOR_STORE_PATH=vector_store
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Logging
LOG_LEVEL=INFO